# CSFloat API key — required for fetching listings and sale history
# Get yours at https://csfloat.com/developers
CSFLOAT_API_KEY=your_api_key_here

# DMarket API keys — optional, enables DMarket listing fetch + buy
# Generate at https://dmarket.com (Account Settings → Trading API)
DMARKET_PUBLIC_KEY=your_public_key_hex
DMARKET_SECRET_KEY=your_secret_key_hex

# Steam Web API key — required for Steam login
# Get yours at https://steamcommunity.com/dev/apikey
STEAM_API_KEY=your_steam_api_key

# Session secret — random string for cookie signing
SESSION_SECRET=change_this_to_random_string

# Base URL — used for Steam OpenID callback
BASE_URL=http://localhost:3001

# Admin Steam ID — gets full access to daemon modal, raw stats
ADMIN_STEAM_ID=your_steam_id_here
