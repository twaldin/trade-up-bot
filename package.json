{
  "name": "trade-up-bot",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:client": "vite",
    "build": "tsc && vite build",
    "postbuild": "npx tsx scripts/prerender.ts",
    "sync": "tsx server/sync.ts",
    "fetch-listings": "tsx server/fetch-listings.ts",
    "calculate": "tsx server/calculate.ts",
    "daemon": "tsx server/daemon.ts",
    "test": "vitest run tests/unit/ tests/integration/",
    "test:unit": "vitest run tests/unit/",
    "test:integration": "vitest run tests/integration/",
    "test:stress": "vitest run tests/stress/",
    "test:all": "vitest run tests/unit/ tests/integration/ tests/stress/",
    "test:watch": "vitest tests/unit/",
    "typecheck": "tsc --noEmit",
    "optimize-images": "node scripts/optimize-images.mjs"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@fontsource-variable/geist": "^5.2.8",
    "@fontsource/inter": "^5.2.8",
    "@resvg/resvg-js": "^2.6.2",
    "@tailwindcss/typography": "^0.5.19",
    "@types/pg": "^8.18.0",
    "better-sqlite3": "^11.7.0",
    "better-sqlite3-session-store": "^0.1.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "discord.js": "^14.25.1",
    "express": "^4.21.0",
    "express-rate-limit": "^7.5.0",
    "express-session": "^1.19.0",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.0",
    "lucide-react": "^0.577.0",
    "passport": "^0.7.0",
    "passport-steam": "^1.0.18",
    "pg": "^8.20.0",
    "react-day-picker": "^9.14.0",
    "react-helmet-async": "^3.0.0",
    "react-router-dom": "^7.13.1",
    "satori": "^0.25.0",
    "shadcn": "^4.0.6",
    "socket.io-client": "^4.8.3",
    "socket.io-msgpack-parser": "^3.0.2",
    "stripe": "^20.4.1",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "tweetnacl": "^1.0.3",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@tanstack/react-table": "^8.20.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/express-session": "^1.18.2",
    "@types/ioredis": "^4.28.10",
    "@types/passport": "^1.0.17",
    "@types/passport-steam": "^1.0.6",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/stripe": "^8.0.416",
    "@types/supertest": "^7.2.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.1.0",
    "fast-check": "^4.6.0",
    "puppeteer": "^24.40.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sharp": "^0.34.5",
    "supertest": "^7.2.2",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^4.1.0"
  }
}
