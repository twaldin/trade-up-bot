# Discord bot token from https://discord.com/developers/applications
DISCORD_BOT_TOKEN=

# Application ID from Discord Developer Portal > General Information
DISCORD_CLIENT_ID=

# OAuth2 secret from Discord Developer Portal > OAuth2
DISCORD_CLIENT_SECRET=

# Your Discord server (guild) ID — right-click server name > Copy Server ID (enable Developer Mode in Settings > Advanced)
DISCORD_GUILD_ID=

# Shared secret for bot -> API internal calls (generate with: openssl rand -hex 32)
INTERNAL_API_TOKEN=

# Discord webhook URLs for alert channels (create in Discord: channel settings > Integrations > Webhooks)
DISCORD_WEBHOOK_KNIFE=
DISCORD_WEBHOOK_COVERT=
DISCORD_WEBHOOK_CLASSIFIED=
DISCORD_WEBHOOK_RESTRICTED=
DISCORD_WEBHOOK_MILSPEC=
DISCORD_WEBHOOK_INDUSTRIAL=
